%% essay.cls
%% Shared look-and-feel for the essay documents.
%% Content files should do:
%%   \documentclass{essay}
%%   \title{...}            % required
%%   \subtitle{...}         % optional, smaller line under the title
%%   \begin{document}
%%   \maketitle
%%   ...
%%   \end{document}
\NeedsTeXFormat{LaTeX2e}
\ProvidesClass{essay}[2026/07/04 Shared essay document class]

\DeclareOption*{\PassOptionsToClass{\CurrentOption}{article}}
\ProcessOptions\relax
\LoadClass[11pt]{article}

% ---------- Fonts & typography ----------
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage{microtype}
\RequirePackage{amsmath,amssymb,amsfonts,mathtools}
\RequirePackage{enumitem}
\setlist{itemsep=2pt,topsep=4pt}

\setlength{\parskip}{5pt}
\setlength{\parindent}{0pt}

% ---------- Page geometry ----------
\RequirePackage[a4paper,margin=1in]{geometry}

% ---------- Title block ----------
\newcommand{\subtitle}[1]{\gdef\@subtitle{#1}}
\gdef\@subtitle{}

% ---------- AI-generated notice ----------
\newcommand{\aigennotice}{%
  \begin{center}
    \small\itshape
    This document was generated by a large language model (LLM) and may contain errors.
  \end{center}
  \vspace{6pt}
}

\renewcommand{\maketitle}{%
  \begin{center}
    {\Huge\bfseries\@title\par}\vspace{12pt}
    \ifx\@subtitle\@empty\else
      {\large\@subtitle\par}\vspace{14pt}
    \fi
    \ifx\@author\@empty\else
      {\normalsize\@author\par}\vspace{8pt}
    \fi
    \ifx\@date\@empty\else
      {\normalsize\@date\par}\vspace{8pt}
    \fi
  \end{center}
  \vspace{6pt}
  \aigennotice
}

% ---------- Theorem-like environments ----------
\RequirePackage{amsthm}
\theoremstyle{plain}
\newtheorem{theorem}{Theorem}[section]
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{corollary}[theorem]{Corollary}

\theoremstyle{definition}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{example}[theorem]{Example}
\newtheorem{exercise}[theorem]{Exercise}
\newtheorem{signature}[theorem]{Signature}

\theoremstyle{remark}
\newtheorem{remark}[theorem]{Remark}
\newtheorem*{note}{Note}

% ---------- Self-check answers ----------
\newenvironment{answer}{\par\smallskip\noindent\textit{Answer.}\enspace}{\par\medskip}

% ---------- Shared math macros ----------
\newcommand{\R}{\mathbb{R}}
\newcommand{\dd}{\mathrm{d}}

% ---------- Tables ----------
\RequirePackage{booktabs}
\RequirePackage{array}

% ---------- Links (loaded last, per hyperref convention) ----------
\RequirePackage{hyperref}
\hypersetup{
  hidelinks,
  pdfstartview=Fit,
}
